---
title: "CX Memory — Data Model"
---
erDiagram
    PROJECT ||--o{ OBSERVATION : contains
    PROJECT ||--o{ DECISION : contains
    PROJECT ||--o{ SESSION : contains
    PROJECT ||--o{ CHANGE : tracks
    
    AUTHOR ||--o{ OBSERVATION : writes
    AUTHOR ||--o{ DECISION : makes
    AUTHOR ||--o{ SESSION : runs
    AUTHOR ||--o{ PERSONAL_NOTE : writes
    
    SESSION ||--o{ OBSERVATION : produces
    SESSION ||--o{ DECISION : produces
    SESSION }|--|| CHANGE : "works on"
    
    CHANGE ||--o{ OBSERVATION : "related to"
    CHANGE }o--o{ SPEC_AREA : affects
    
    OBSERVATION }o--o{ SPEC_AREA : "relates to"
    DECISION }o--o{ SPEC_AREA : "affects"
    DECISION ||--o| DECISION : deprecates
    DECISION ||--o| OBSERVATION : deprecates
    OBSERVATION ||--o| OBSERVATION : deprecates
    
    PROJECT {
        string path "repo root path"
        string name "from docs/overview.md H1"
    }
    
    AUTHOR {
        string id "git config user.name"
        string email "git config user.email"
    }
    
    OBSERVATION {
        string id "unique slug"
        string type "bugfix | discovery | pattern | context"
        string title "short description"
        string content "full markdown body"
        string author "who wrote it"
        string session_id "which session produced it"
        string change_id "optional: which change it relates to"
        string[] file_refs "optional: files in codebase"
        string[] spec_refs "optional: specs areas affected"
        string deprecates "optional: slug of observation this replaces"
        string[] tags "searchable tags"
        datetime created_at "timestamp"
    }

    DECISION {
        string id "unique slug"
        string title "what was decided"
        string context "why this decision was needed"
        string outcome "what we chose"
        string[] alternatives "what we considered"
        string rationale "why we chose it"
        string[] tradeoffs "known tradeoffs"
        string deprecates "optional: slug of entity this replaces"
        string status "active | superseded | cancelled"
        string author "who made it"
        string change_id "optional: which change prompted it"
        string[] spec_refs "specs affected"
        string[] tags "searchable tags"
        datetime created_at "timestamp"
    }
    
    SESSION {
        string id "auto-generated"
        string author "who ran the session"
        string change_id "optional: what change was active"
        string goal "what the session aimed to do"
        string[] discoveries "what was learned"
        string[] accomplished "what was done"
        string[] files_touched "files modified"
        string next_steps "what to do next"
        datetime started_at "session start"
        datetime ended_at "session end"
    }
    
    PERSONAL_NOTE {
        string id "auto-generated"
        string type "pattern | preference | tool_tip | reminder"
        string title "short description"
        string content "full content"
        string[] projects "optional: relevant projects"
        string[] tags "searchable tags"
        datetime created_at "timestamp"
        datetime updated_at "for upserts"
        string topic_key "optional: for upsert dedup"
    }
    
    CHANGE {
        string id "directory name in docs/changes/"
        string status "active | archived"
    }
    
    SPEC_AREA {
        string path "e.g. device-communication"
    }
