---
title: "Entity Lifecycles"
---
stateDiagram-v2
    state "Observation" as obs {
        [*] --> created: cx memory save
        created --> [*]: lives forever (append-only)
        note right of created
            Immutable historical fact.
            Never modified, never deleted.
            May become outdated — new
            observations or decisions
            deprecate it, but the record stays.
        end note
    }

    state "Decision" as dec {
        [*] --> active: cx memory decide
        active --> superseded: new decision deprecates this one
        active --> cancelled: constraint no longer applies
        active --> [*]: still the current truth
        superseded --> [*]: kept as history
        cancelled --> [*]: kept as history
        note right of active
            Has rationale, alternatives,
            tradeoffs. Deprecation creates
            a chain showing WHY things changed.
        end note
    }

    state "Session" as sess {
        [*] --> recorded: cx memory session
        recorded --> [*]: lives as history
        note right of recorded
            Most recent session for an author
            is the primary recovery point.
            Older sessions are audit trail.
        end note
    }

    state "Personal Note" as note {
        [*] --> saved: cx memory note
        saved --> updated: cx memory note (same topic_key)
        updated --> updated: can update again
        saved --> deleted: cx memory forget
        updated --> deleted: cx memory forget
        note right of saved
            Only entity that supports
            upsert and deletion.
            Personal, cross-project,
            never synced.
        end note
    }
